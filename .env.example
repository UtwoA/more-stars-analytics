RAILS_ENV=development
APP_TIME_ZONE=Europe/Moscow

# Use the same PostgreSQL as core more-stars to read raw data.
# For local standalone testing you can keep docker-compose default.
DATABASE_URL=postgresql://analytics:analytics@db:5432/more_stars
TEST_DATABASE_URL=postgresql://analytics:analytics@db:5432/more_stars_test

REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=*

# Dashboard auth (required)
DASHBOARD_PASSWORD=change_me

# Google Authenticator secret (base32). Generate:
# docker compose run --rm app bundle exec rake auth:generate_2fa_secret
DASHBOARD_2FA_SECRET=
TOTP_ISSUER=more-stars-analytics
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false
GIFT_DEFAULT_COST_RUB=60

# Optional machine-to-machine API token.
# If set, requests with X-Internal-Token are allowed without web session.
INTERNAL_API_TOKEN=
